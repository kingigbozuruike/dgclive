# Backend Environment Variables for Production
# Set these in your hosting platform (Railway, Render, Fly.io, etc.)

# Server Configuration
PORT=3001

# Database - Use Supabase Session Pooler (port 5432)
# Find in Supabase Dashboard → Project Settings → Database → Connection Pooler
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?pgbouncer=true&sslmode=require"

# Supabase Admin Keys
# Find in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# CORS Configuration - List your frontend domains (comma-separated)
# Example: https://yourdomain.vercel.app,https://www.yourdomain.vercel.app
CORS_ORIGINS=https://yourdomain.vercel.app

# Add any other environment variables your handlers need:
# - Google OAuth credentials
# - Mux API keys
# - Email service credentials
# - etc.
