generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Roles (Kept Simple)
enum Role {
  MEMBER
  MEDIA
  ADMIN
}

// 1.5. Notification Types
enum NotificationType {
  UPCOMING_SERVICE
  LIVESTREAM_STARTED
  NEW_VIDEO
}

// 2. Profile (Matches Supabase Auth)
model Profile {
  id        String   @id // Maps to Supabase Auth ID
  email     String   @unique
  fullName  String
  role      Role     @default(MEMBER)
  isBanned  Boolean  @default(false) // banned from chat
  createdAt DateTime @default(now())

  // Relationships
  inviteId  String?  @unique
  invite    GlobalInvite? @relation(fields: [inviteId], references: [id])
  messages  ChatMessage[]
  notifications Notification[]
}

// 3. The "Church Entry" Ticket (PRD 6.1)
// This is what allows them to Register.
model GlobalInvite {
  id        String   @id @default(uuid())
  code      String   @unique // e.g. "GRACE-2026"
  isUsed    Boolean  @default(false)
  issuedTo  String?  // e.g. "Deacon John"
  
  // Who used it?
  usedBy    Profile?
}

// 4. The Livestream Service (PRD 6.2)
// Renamed 'Event' to 'Livestream' for clarity, or keep 'Event' if you prefer.
model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  isPublic    Boolean  @default(false) // If false, only Members can watch
  isLive      Boolean  @default(false)
  isPublished Boolean  @default(false) // Published to members/public (separate from isLive)

  // --- MUX VIDEO DATA (Critical Addition) ---
  muxPlaybackId String? // For the Frontend Player
  muxStreamKey  String? // For OBS (Hidden)
  muxAssetId    String? // For On-Demand Replay

  thumbnailUrl  String? // <--- Uploaded by User

  // --- INTERACTION ---
  chatMessages ChatMessage[]
}

// 5. Chat & Comments (PRD 6.3)
model ChatMessage {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())

  // Who sent it?
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])

  // Which Event?
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id])
}

// 5.5. Notifications (Real-time alerts)
model Notification {
  id              String           @id @default(uuid())
  type            NotificationType
  title           String
  description     String
  relatedEntityId String?          // Optional: FK to Event or YouTubeVideo
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  // Who receives it?
  userId          String
  user            Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// 6. Email Verification (For Signup Flow)
model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String   // 6-digit code (hashed in production)
  createdAt DateTime @default(now())
  expiresAt DateTime // Calculated as createdAt + VERIFICATION_CODE_EXPIRES_IN
  used      Boolean  @default(false)

  @@index([email])
  @@index([expiresAt])
}

// 7. YouTube Archive Videos (Legacy Sermons)
model YouTubeVideo {
  id            String   @id @default(cuid())
  youtubeId     String   @unique
  title         String
  description   String   @db.Text
  thumbnailUrl  String
  duration      Int
  publishedAt   DateTime
  viewCount     Int
  channelId     String
  channelTitle  String
  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([publishedAt])
}

